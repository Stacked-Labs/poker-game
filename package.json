{
    "name": "poker-game",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint --fix",
        "lint:copy": "node scripts/check-copy.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:free": "playwright test e2e/free/ --workers=4 --fully-parallel",
        "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky install; fi",
        "format": "prettier --write '*/**/*.{js,jsx,ts,tsx,json,css,scss,md}'",
        "lighthouse:desktop": "npx lighthouse http://localhost:3000 --view --preset=desktop",
        "lighthouse:mobile": "npx lighthouse http://localhost:3000 --view --emulated-form-factor=mobile",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "storybook build"
    },
    "dependencies": {
        "@chakra-ui/next-js": "^2.1.5",
        "@chakra-ui/react": "^2.8.1",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@farcaster/miniapp-sdk": "^0.2.2",
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.9",
        "@types/canvas-confetti": "^1.9.0",
        "@types/node": "^20",
        "blo": "^2.0.0",
        "canvas-confetti": "^1.9.4",
        "dotenv": "^16.3.1",
        "framer-motion": "^10.16.4",
        "html-to-image": "^1.11.13",
        "next": "15.5.18",
        "posthog-js": "^1.376.0",
        "react": "^18",
        "react-dom": "^18",
        "react-icons": "^5.5.0",
        "react-markdown": "^10.1.0",
        "react-turnstile": "^1.1.4",
        "react-virtuoso": "^4.7.2",
        "remark-gfm": "^4.0.1",
        "thirdweb": "^5.120.0",
        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "@johanneskares/wallet-mock": "^1.4.1",
        "@playwright/test": "^1.58.2",
        "@storybook/addon-docs": "^9.1.20",
        "@storybook/addon-themes": "^9.1.20",
        "@storybook/nextjs-vite": "^9.1.20",
        "@storybook/react": "^9.1.20",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "@vitejs/plugin-react": "^4.7.0",
        "eslint": "^8.57.0",
        "eslint-config-next": "15.5.18",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.2",
        "eslint-plugin-react": "^7.33.2",
        "husky": "^8.0.3",
        "jsdom": "^25.0.1",
        "lint-staged": "^15.2.7",
        "prettier": "^3.0.3",
        "storybook": "^9.1.20",
        "typescript": "^5",
        "viem": "^2.47.5",
        "vite": "^7.0.0",
        "vitest": "^2.1.9"
    },
    "husky": {
        "hooks": {
            "pre-commit": "npm run lint && npm run build"
        }
    }
}
